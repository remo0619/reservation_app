<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      
      <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
          <h4 class="mb-0 fw-bold text-center">アカウント設定</h4>
        </div>
        
        <div class="card-body p-4">
          <%= form_with model: @user, url: update_account_user_path(current_user), method: :patch, local: true do |f| %>
            
            <div class="mb-4">
              <%= f.label :email, "メールアドレス", class: "form-label fw-bold" %>
              <%= f.email_field :email, class: "form-control" %>
              <% if @user.errors[:email].any? %>
                <div class="invalid-feedback d-block small">
                  <%= @user.errors.full_messages_for(:email).first %>
                </div>
              <% end %>
            </div>

            <hr class="my-4">
            <p class="text-muted small mb-3">パスワードを変更する場合のみ、以下を入力してください。</p>

            <div class="mb-3">
              <%= f.label :current_password, "現在のパスワード", class: "form-label fw-bold" %>
              <%= f.password_field :current_password, class: "form-control" %>
              <% if @user.errors[:current_password].any? %>
                <div class="invalid-feedback d-block small">
                  <%= @user.errors.full_messages_for(:current_password).first %>
                </div>
              <% end %>
            </div>

            <div class="mb-3">
              <%= f.label :password, "新しいパスワード", class: "form-label fw-bold" %>
              <%= f.password_field :password, class: "form-control" %>
              <% if @user.errors[:password].any? %>
                <div class="invalid-feedback d-block small">
                  <%= @user.errors.full_messages_for(:password).first %>
                </div>
              <% end %>
            </div>

            <div class="mb-4">
              <%= f.label :password_confirmation, "新しいパスワード（確認）", class: "form-label fw-bold" %>
              <%= f.password_field :password_confirmation, class: "form-control" %>
              <% if @user.errors[:password_confirmation].any? %>
                <div class="invalid-feedback d-block small">
                  <%= @user.errors.full_messages_for(:password_confirmation).first %>
                </div>
              <% end %>
            </div>

            <div class="d-grid gap-2 mt-4">
              <%= f.submit "アカウント情報を更新する", class: "btn btn-primary btn-lg fw-bold" %>
              <%= link_to "マイページに戻る", user_path(current_user), class: "btn btn-link text-secondary text-decoration-none" %>
            </div>

          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>