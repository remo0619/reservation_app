<h3>ユーザー設定</h3>
<%= form_with model: @user do |f| %>
  <table>
    <tr>
      <th><%= f.label :name , "ユーザー名" %></th>
      <td><%= f.text_field :name %></td>
    </tr>
    <tr>
      <th><% f.label :email , "メールアドレス" %></th>
      <td><%= f.email_field :email %></td>
    </tr>
    <tr>
      <th>パスワード</th>
      <td>**********</td>
    </tr>
  </table>

  <div>
    <ul>
      <li><%= f.submit "更新" %></li>
      <li><%= link_to "ユーザー一覧", users_path %></li>
    </ul>
  </div>
<% end %>
