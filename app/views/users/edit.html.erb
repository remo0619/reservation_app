<h3>アカウント設定</h3>

<%= form_with model: @user do |f| %>
  <table>
    <tr>
      <th><%= f.label :avatar , "プロフィール画像" %></th>
      <td>
        <%= f.label :avatar do %>
          <% if @user.avatar.attached? && @user.avatar.variable? %>
            <%= image_tag @user.avatar.variant(resize: "100x100") %>
            <%= f.file_field :avatar, style: 'display:none' %>
            <% if @user.errors[:avatar].any? %>
              <div class="invalid-feedback d-block small">
                <% @user.errors.full_messages.each do |message| %>
                  <%= message %>
                <% end %>
              </div>
            <% end %>
          <% end %>  
        <% end %>
      </td>
    </tr>
    <tr>
      <th><%= f.label :name , "ユーザー名" %></th>
      <td>
        <%= f.text_field :name %>
        <% if @user.errors[:name].any? %>
          <div class="invalid-feedback d-block small">
            <%= @user.errors.full_messages_for(:name).first %>
          </div>
        <% end %>
      </td>
    </tr>
    <tr>
      <th><%= f.label :email , "メールアドレス" %></th>
      <td>
        <%= f.email_field :email %>
        <% if @user.errors[:email].any? %>
          <div class="invalid-feedback d-block small">
            <%= @user.errors.full_messages_for(:email).first %>
          </div>
        <% end %>
      </td>
    </tr>
    <tr>
      <th><%= f.label :bio , "自己紹介" %></th>
      <td>
        <%= f.text_area :bio %>
        <% if @user.errors[:bio].any? %>
          <div class="invalid-feedback d-block small">
            <%= @user.errors.full_messages_for(:bio).first %>
          </div>
        <% end %>
      </td>
    </tr>
    <tr>
      <th>パスワード</th>
      <td>**********</td>
    </tr>
  </table>

  <div>
    <ul>
      <li><%= f.submit "更新" %></li>
      <li><%= link_to "マイページ", user_path(current_user) %></li>
    </ul>
  </div>
<% end %>
