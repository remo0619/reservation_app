<h3>アカウント設定</h3>

<% if @user.avatar.attached? %>
  <p>
    <strong><%= User.human_attribute_name(:avatar) %></strong>
    <%= image_tag @user.avatar.variant(resize: "100x100") %>
  </p>
<% end %>

<%= form_with model: @user do |f| %>
  <div>
    <%= f.label :avatar , "プロフィール画像" %>
    <%= f.file_field :avatar %>
  </div>

  <table>
    <tr>
      <th><%= f.label :name , "ユーザー名" %></th>
      <td><%= f.text_field :name %></td>
    </tr>
    <tr>
      <th><%= f.label :email , "メールアドレス" %></th>
      <td><%= f.email_field :email %></td>
    </tr>
    <tr>
      <th><%= f.label :bio , "自己紹介" %></th>
      <td><%= f.text_area :bio %></td>
    </tr>
    <tr>
      <th>パスワード</th>
      <td>**********</td>
    </tr>
  </table>

  <div>
    <ul>
      <li><%= f.submit "更新" %></li>
      <li><%= link_to "マイページ", user_path(current_user) %></li>
    </ul>
  </div>
<% end %>
