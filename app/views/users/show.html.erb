<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      
      <div class="text-center mb-5">
        <div class="mb-3">
          <% if @user.avatar.attached? && @user.avatar.variable? %>
            <%= image_tag @user.avatar.variant(resize_to_limit: [150, 150]), 
                          class: "rounded-circle shadow-sm border", 
                          style: "width: 150px; height: 150px; object-fit: cover;" %>
          <% else %>
            <%= image_tag "default_avatar.png", class: "rounded-circle shadow-sm border", style: "width: 150px; height: 150px;" %>
          <% end %>
        </div>
        <h3 class="fw-bold"><%= @user.name %></h3>
        <p class="text-muted"><%= @user.bio %></p>
      </div>

      <div class="card shadow-sm mb-4">
        <div class="card-header d-flex justify-content-between align-items-center py-3">
          <h5 class="mb-0 fw-bold">プロフィール情報</h5>
          <%= link_to "編集", edit_profile_user_path(current_user), class: "btn btn-sm btn-outline-primary px-3" %>
        </div>
        <div class="card-body">
          <div class="row mb-3">
            <div class="col-4 text-muted small">ユーザー名</div>
            <div class="col-8 fw-bold"><%= @user.name %></div>
          </div>
          <div class="row">
            <div class="col-4 text-muted small">自己紹介</div>
            <div class="col-8"><%= @user.bio.presence || "未設定" %></div>
          </div>
        </div>
      </div>

      <div class="card shadow-sm mb-5">
        <div class="card-header d-flex justify-content-between align-items-center py-3">
          <h5 class="mb-0 fw-bold">アカウント情報</h5>
          <%= link_to "編集", edit_account_user_path(current_user), class: "btn btn-sm btn-outline-primary px-3" %>
        </div>
        <div class="card-body">
          <div class="row mb-3 border-bottom pb-2">
            <div class="col-4 text-muted small">メールアドレス</div>
            <div class="col-8"><%= @user.email %></div>
          </div>
          <div class="row pt-1">
            <div class="col-4 text-muted small">パスワード</div>
            <div class="col-8 text-muted">**********</div>
          </div>
        </div>
      </div>

      <div class="text-center">
        <%= link_to "トップページに戻る", root_path, class: "btn btn-link text-secondary" %>
      </div>

    </div>
  </div>
</div>