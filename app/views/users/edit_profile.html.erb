<h3>プロフィール設定</h3>

<%= form_with model: @user, url: update_profile_user_path(current_user), method: :patch do |f| %>
  <table>
    <tr>
      <th><%= f.label :avatar , "プロフィール画像" %></th>
      <td>
        <%= f.label :avatar do %>
          <%= f.file_field :avatar, style: 'display:none', onchange: "previewImage(this)", accept: "image/jpeg,image/gif,image/png" %>
          <% if @user.avatar.attached? && @user.avatar.variable? %>
            <%= image_tag @user.avatar.variant(resize: "100x100"), 
                          id: "preview", 
                          class: "rounded-circle avatar-image-clickable", 
                          style: "width: 100px; height: 100px; object-fit: cover;" %>

            <% # 画像削除チェックボックス %>
            <div class="form-check">
              <%= f.check_box :remove_avatar, class: "form-check-input" %>
              <%= f.label :remove_avatar, "現在の画像を削除する", class: "form-check-label text-danger" %>
            </div>

            <% # エラーメッセージ表示 %>
            <% if @user.errors[:avatar].any? %>
              <div class="invalid-feedback d-block small">
                <% @user.errors.full_messages.each do |message| %>
                  <%= message %>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <% # 画像が紐付いていない場合、デフォルト画像を表示 %>
            <%= image_tag "default_avatar.png", id: "preview", size: "100x100", class: "rounded-circle avatar-image-clickable" %>
          <% end %>
        <% end %>
      </td>
    </tr>
    <tr>
      <th><%= f.label :name , "ユーザー名" %></th>
      <td>
        <%= f.text_field :name %>
        <% if @user.errors[:name].any? %>
          <div class="invalid-feedback d-block small">
            <%= @user.errors.full_messages_for(:name).first %>
          </div>
        <% end %>
      </td>
    </tr>
    <tr>
      <th><%= f.label :bio , "自己紹介" %></th>
      <td>
        <%= f.text_area :bio %>
        <% if @user.errors[:bio].any? %>
          <div class="invalid-feedback d-block small">
            <%= @user.errors.full_messages_for(:bio).first %>
          </div>
        <% end %>
      </td>
    </tr>
  </table>

  <div>
    <ul>
      <li><%= f.submit "更新" %></li>
      <li><%= link_to "マイページ", user_path(current_user) %></li>
    </ul>
  </div>
<% end %>
