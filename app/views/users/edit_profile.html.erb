<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      
      <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
          <h4 class="mb-0 fw-bold text-center">プロフィール設定</h4>
        </div>
        
        <div class="card-body p-4">
          <%= form_with model: @user, url: update_profile_user_path(current_user), method: :patch, local: true do |f| %>
            
            <div class="text-center mb-4">
              <%= f.label :avatar, class: "d-block" do %>
                <% if @user.avatar.attached? && @user.avatar.variable? %>
                  <%= image_tag @user.avatar.variant(resize_to_limit: [120, 120]), 
                                id: "preview", 
                                class: "rounded-circle border shadow-sm", 
                                style: "width: 120px; height: 120px; object-fit: cover; cursor: pointer;" %>
                <% else %>
                  <%= image_tag "default_avatar.png", id: "preview", class: "rounded-circle border shadow-sm", style: "width: 120px; height: 120px; cursor: pointer;" %>
                <% end %>
                
                <%= f.file_field :avatar, style: 'display:none', onchange: "previewImage(this)", accept: "image/jpeg,image/gif,image/png" %>
              <% end %>

              <% if @user.avatar.attached? %>
                <div class="form-check d-inline-block mt-1">
                  <%= f.check_box :remove_avatar, class: "form-check-input" %>
                  <%= f.label :remove_avatar, "現在の画像を削除する", class: "form-check-label small text-danger mt-2" %>
                </div>
              <% end %>
            </div>

            <div class="mb-3">
              <%= f.label :name, "ユーザー名", class: "form-label fw-bold" %>
              <%= f.text_field :name, class: "form-control " %>
              <% if @user.errors[:name].any? %>
                <div class="invalid-feedback d-block small">
                  <%= @user.errors.full_messages_for(:name).first %>
                </div>
              <% end %>
            </div>

            <div class="mb-4">
              <%= f.label :bio, "自己紹介", class: "form-label fw-bold" %>
              <%= f.text_area :bio, rows: 4, class: "form-control" %>
              <% if @user.errors[:bio].any? %>
                <div class="invalid-feedback d-block small">
                  <%= @user.errors.full_messages_for(:bio).first %>
                </div>
              <% end %>
            </div>

            <div class="d-grid gap-2 mt-4">
              <%= f.submit "変更を保存する", class: "btn btn-primary btn-lg fw-bold" %>
              <%= link_to "マイページに戻る", user_path(current_user), class: "btn btn-link text-secondary text-decoration-none" %>
            </div>

          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>