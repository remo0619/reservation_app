<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
      
      <div class="card shadow-sm">
        <div class="card-header py-3">
          <h4 class="mb-0 fw-bold text-center">施設情報編集</h4>
        </div>
        
        <div class="card-body p-4">
          <%= form_with model: @room, local: true do |f| %>
            
            <div class="mb-4 text-center">
              <%= f.label :image, class: "d-block mx-auto", style: "cursor: pointer;" do %>
                <div class="border rounded bg-light d-flex align-items-center justify-content-center overflow-hidden" style="width: 100%; height: 250px;">
                  <% if @room.image.attached? && @room.image.variable? %>
                    <%= image_tag @room.image, id: "preview", class: "w-100 h-100", style: "object-fit: cover;" %>
                  <% else %>
                    <%= image_tag "default-image.png", id: "preview", class: "w-100 h-100", style: "object-fit: cover;" %>
                  <% end %>
                </div>
                <%= f.file_field :image, style: 'display:none', onchange: "previewImage(this)", accept: "image/jpeg,image/gif,image/png" %>
              <% end %>
              <p class="small text-muted mt-2">※クリックして画像をアップロード</p>
              <% if @room.errors[:image].any? %>
                <div class="invalid-feedback d-block small"><%= @room.errors.full_messages_for(:image).first %></div>
              <% end %>
            </div>

            <div class="mb-3">
              <%= f.label :name, "施設名", class: "form-label fw-bold" %>
              <%= f.text_field :name, class: "form-control" %>
              <% if @room.errors[:name].any? %>
                <div class="invalid-feedback d-block small">
                  <%= @room.errors.full_messages_for(:name).first %>
                </div>
              <% end %>
            </div>

            <div class="mb-3">
              <%= f.label :introduction, "施設詳細", class: "form-label fw-bold" %>
              <%= f.text_area :introduction, rows: 5, class: "form-control" %>
              <% if @room.errors[:introduction].any? %>
                <div class="invalid-feedback d-block small">
                  <%= @room.errors.full_messages_for(:introduction).first %>
                </div>
              <% end %>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <%= f.label :price, "1日あたりの料金 (¥)", class: "form-label fw-bold" %>
                <%= f.number_field :price, class: "form-control" %>
                <% if @room.errors[:price].any? %>
                  <div class="invalid-feedback d-block small">
                    <%= @room.errors.full_messages_for(:price).first %>
                  </div>
                <% end %>
              </div>

              <div class="col-md-6 mb-3">
                <%= f.label :address, "住所", class: "form-label fw-bold" %>
                <%= f.text_field :address, class: "form-control" %>
                <% if @room.errors[:address].any? %>
                  <div class="invalid-feedback d-block small">
                    <%= @room.errors.full_messages_for(:address).first %>
                  </div>
                <% end %>
              </div>
            </div>

            <div class="d-grid gap-2 mt-4">
              <%= f.submit "編集を完了する", class: "btn btn-primary btn-lg fw-bold" %>
              <%= link_to "この施設を削除する", 
              room_path(@room), 
              data: { turbo_method: :delete, turbo_confirm: "本当に削除してもよろしいですか？" }, 
              class: "btn btn-danger" %>
              <%= link_to "マイページに戻る", user_path(current_user), class: "btn btn-link text-secondary text-decoration-none" %>
            </div>

          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>