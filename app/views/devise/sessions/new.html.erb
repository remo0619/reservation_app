<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      
      <div class="card shadow-sm">
        <div class="card-header py-3">
          <h4 class="mb-0 fw-bold text-center">ログイン</h4>
        </div>
        
        <div class="card-body p-4">
          <% if flash[:alert] %>
            <div class="invalid-feedback d-block small mb-3">
              <%= flash[:alert] %>
            </div>
          <% end %>

          <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
            
            <div class="mb-3">
              <%= f.label :email, "メールアドレス", class: "form-label fw-bold" %>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "example@mail.com" %>
            </div>

            <div class="mb-3">
              <%= f.label :password, "パスワード", class: "form-label fw-bold" %>
              <%= f.password_field :password, autocomplete: "current-password", class: "form-control", placeholder: "パスワードを入力" %>
            </div>

            <% if devise_mapping.rememberable? %>
              <div class="form-check mb-4">
                <%= f.check_box :remember_me, class: "form-check-input" %>
                <%= f.label :remember_me, "次回から自動的にログイン", class: "form-check-label small text-muted" %>
              </div>
            <% end %>

            <div class="d-grid gap-2 mb-3">
              <%= f.submit "ログインする", class: "btn btn-primary btn-lg fw-bold" %>
            </div>
          <% end %>

          <div class="text-center border-top pt-3">
            <%= render "devise/shared/links" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>